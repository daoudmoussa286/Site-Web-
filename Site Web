import React, { useState, useRef, useEffect } from "react";

// Single-file React app for a beginner-friendly programming learning site. // TailwindCSS utility classes are used for styling (assumes Tailwind is configured in the host project).

const LESSONS = [ { id: 1, title: "Introduction à la programmation", summary: "Variables, types, et affichage", content: Les variables permettent de stocker des valeurs. Exemple en JavaScript:\n\nlet message = 'Bonjour';\nconsole.log(message);\n\nTape du code dans l'éditeur et clique sur Run pour l'exécuter., starterCode: // Essayez ceci:\nconsole.log('Bonjour monde');\n, quiz: { question: "Quelle instruction affiche du texte dans la console en JavaScript ?", options: ["print()", "echo()", "console.log()", "write()"], answerIndex: 2, }, }, { id: 2, title: "Structures conditionnelles", summary: "if / else", content: Les structures conditionnelles permettent de choisir des actions selon des conditions. Exemple :\n\nif (x > 0) { console.log('positif') } else { console.log('non-positif') }, starterCode: const x = 5;\nif (x > 0) {\n  console.log('positif');\n} else {\n  console.log('non-positif');\n}\n, quiz: { question: "Quel mot-clé commence une condition en JavaScript ?", options: ["for", "if", "while", "switch"], answerIndex: 1, }, }, { id: 3, title: "Boucles", summary: "for, while", content: Les boucles répètent du code. Exemple :\n\nfor (let i = 0; i < 3; i++) { console.log(i) }, starterCode: for (let i = 0; i < 3; i++) {\n  console.log('i =', i);\n}\n, quiz: { question: "Quelle boucle exécute une action tant que la condition est vraie ?", options: ["for", "do...while", "while", "switch"], answerIndex: 2, }, }, ];

export default function LearnCodeApp() { const [selectedLessonId, setSelectedLessonId] = useState(LESSONS[0].id); const [code, setCode] = useState(LESSONS[0].starterCode); const [consoleLines, setConsoleLines] = useState([]); const iframeRef = useRef(null); const [quizResult, setQuizResult] = useState(null); const [query, setQuery] = useState("");

useEffect(() => { const lesson = LESSONS.find((l) => l.id === selectedLessonId); setCode(lesson.starterCode); setConsoleLines([]); setQuizResult(null); }, [selectedLessonId]);

function runCode() { // Prepare the code that overrides console.log and posts messages to the parent via postMessage. const wrapped = (function(){ const originalLog = console.log; function send(...args){ parent.postMessage({ type: 'learncode:log', args: args.map(a => { try { return JSON.stringify(a); } catch(e) { return String(a); } }) }, '*'); } console.log = function(){ send(...arguments); originalLog.apply(console, arguments); } try { ${code} } catch(err) { parent.postMessage({ type: 'learncode:error', error: String(err) }, '*'); } })();;

// Write the wrapped code into the iframe and execute it safely inside sandbox
const iframe = iframeRef.current;
if (!iframe) return;
const doc = iframe.contentDocument || iframe.contentWindow.document;
doc.open();
doc.write(`<html><body><script>\n${wrapped}\n<\/script></body></html>`);
doc.close();

}

useEffect(() => { function handleMessage(e) { const data = e.data || {}; if (data.type === 'learncode:log') { // data.args is array of json strings const parsed = data.args.map(a => { try { return JSON.parse(a); } catch(e) { return a; } }); setConsoleLines((s) => [...s, parsed.join(' ')]); } if (data.type === 'learncode:error') { setConsoleLines((s) => [...s, 'Erreur: ' + data.error]); } } window.addEventListener('message', handleMessage); return () => window.removeEventListener('message', handleMessage); }, []);

function submitQuiz(choiceIndex) { const lesson = LESSONS.find((l) => l.id === selectedLessonId); const correct = lesson.quiz.answerIndex === choiceIndex; setQuizResult(correct ? 'Bonne réponse 🎉' : 'Incorrect — réessaie 😅'); }

const filteredLessons = LESSONS.filter(l => l.title.toLowerCase().includes(query.toLowerCase()) || l.summary.toLowerCase().includes(query.toLowerCase()) );

const lesson = LESSONS.find(l => l.id === selectedLessonId);

return ( <div className="min-h-screen bg-gray-50 text-gray-800"> <header className="bg-gradient-to-r from-indigo-600 to-indigo-400 text-white p-4 shadow-md"> <div className="max-w-6xl mx-auto flex items-center justify-between"> <h1 className="text-2xl font-bold">LearnCode</h1> <nav className="text-sm opacity-90">Apprends la programmation — simple et fun</nav> </div> </header>

<main className="max-w-6xl mx-auto p-4 grid grid-cols-1 md:grid-cols-4 gap-4">
    <aside className="md:col-span-1 bg-white rounded-2xl p-4 shadow-sm">
      <div className="mb-4">
        <input value={query} onChange={e => setQuery(e.target.value)} placeholder="Recherche..." className="w-full border rounded p-2 text-sm" />
      </div>
      <div className="space-y-2">
        {filteredLessons.map(l => (
          <button
            key={l.id}
            onClick={() => setSelectedLessonId(l.id)}
            className={`block w-full text-left p-3 rounded-lg ${l.id === selectedLessonId ? 'bg-indigo-50 border border-indigo-200' : 'hover:bg-gray-50'}`}>
            <div className="font-semibold">{l.title}</div>
            <div className="text-xs opacity-80">{l.summary}</div>
          </button>
        ))}
      </div>
    </aside>

    <section className="md:col-span-3 space-y-4">
      <div className="bg-white rounded-2xl p-4 shadow-sm">
        <h2 className="text-xl font-bold">{lesson.title}</h2>
        <p className="mt-2 whitespace-pre-line">{lesson.content}</p>
      </div>

      <div className="bg-white rounded-2xl p-4 shadow-sm grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div>
          <div className="flex items-center justify-between mb-2">
            <strong>Éditeur de code</strong>
            <div className="text-sm opacity-80">JavaScript • Exécute dans un sandbox</div>
          </div>
          <textarea value={code} onChange={e => setCode(e.target.value)} className="w-full h-64 border rounded p-2 font-mono text-sm" />
          <div className="flex gap-2 mt-2">
            <button onClick={runCode} className="px-4 py-2 rounded bg-indigo-600 text-white">Run</button>
            <button onClick={() => { setCode(lesson.starterCode); setConsoleLines([]); }} className="px-4 py-2 rounded border">Reset</button>
          </div>

          <div className="mt-4">
            <strong>Console</strong>
            <div className="mt-2 bg-black text-white rounded p-2 h-40 overflow-auto text-sm font-mono">
              {consoleLines.length === 0 ? <div className="opacity-60">La console est vide — exécutez le code.</div> : consoleLines.map((ln, i) => <div key={i}>{ln}</div>)}
            </div>
          </div>
        </div>

        <div>
          <strong>Preview sandbox</strong>
          <div className="mt-2 border rounded overflow-hidden h-64">
            <iframe title="sandbox" ref={iframeRef} sandbox="allow-scripts" style={{ width: '100%', height: '100%', border: 0 }} />
          </div>

          <div className="mt-4">
            <strong>Quiz rapide</strong>
            <div className="mt-2 bg-gray-50 rounded p-3">
              <div className="font-medium">{lesson.quiz.question}</div>
              <div className="mt-2 space-y-2">
                {lesson.quiz.options.map((opt, idx) => (
                  <button key={idx} onClick={() => submitQuiz(idx)} className="block w-full text-left p-2 rounded hover:bg-white border">{opt}</button>
                ))}
              </div>
              {quizResult && <div className="mt-3 p-2 rounded text-sm">{quizResult}</div>}
            </div>

            <div className="mt-4">
              <strong>Ressources</strong>
              <ul className="mt-2 list-disc ml-5 text-sm opacity-90">
                <li>MDN Web Docs (JavaScript)</li>
                <li>freeCodeCamp</li>
                <li>Exercices pratiques intégrés</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div className="bg-white rounded-2xl p-4 shadow-sm flex items-center justify-between">
        <div>
          <div className="text-sm opacity-80">Progrès: <strong>débutant</strong></div>
          <div className="text-xs opacity-60">Complétez les leçons et faites les quiz pour monter en compétence.</div>
        </div>
        <div>
          <button onClick={() => alert('Fonctionnalité d'export à venir — mais tu peux copier le code directement.')} className="px-4 py-2 border rounded">Exporter le code</button>
        </div>
      </div>

    </section>
  </main>

  <footer className="text-center p-4 text-xs opacity-80">Made with ❤️ — Start small, build big.</footer>
</div>

); }
